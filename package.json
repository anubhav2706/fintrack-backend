{
  "name": "fintrack-backend",
  "version": "1.0.0",
  "description": "Production-ready REST API for the FinTrack Pro Android app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "finance",
    "tracking",
    "api",
    "nodejs",
    "mongodb",
    "express"
  ],
  "author": "FinTrack Pro Team",
  "license": "MIT",
